# ===========================================
# x402 Demo — Environment Configuration
# ===========================================
# Copy this file to .env and fill in required values.
# Default chain: Base Sepolia (eip155:84532)

# --- Shared ---
NETWORK=eip155:84532
RPC_URL=https://sepolia.base.org
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
LOG_LEVEL=info

# Transfer method: eip3009 (default, USDC only) or permit2 (any ERC-20)
ASSET_TRANSFER_METHOD=eip3009

# --- Facilitator Server ---
FACILITATOR_PRIVATE_KEY=0x...your_facilitator_private_key...
FACILITATOR_PORT=4022

# --- Resource Server ---
FACILITATOR_URL=http://localhost:4022
PAY_TO_ADDRESS=0x...your_recipient_address...
RESOURCE_PORT=4021

# --- Client CLI ---
CLIENT_PRIVATE_KEY=0x...your_client_private_key...
RESOURCE_URL=http://localhost:4021
ENDPOINT_PATH=/weather
